[background arg="res://Assets/Noraneko_Backgrounds_Pack_3/Noraneko_Backgrounds_Pack_3/Temple_Spring_Night.png" fade="1.5" wait="true"]
[background arg="res://Assets/Noraneko_Backgrounds_Pack_3/Noraneko_Backgrounds_Pack_3/Temple_Spring_Rain.png" fade="1.5" wait="true"]
