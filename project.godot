config/icon="res://icon.svg"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"
Affection_System="*uid://c1wj7dvsxywk2"
Health_System="*uid://kbq5try170rc"
Meal_System="*uid://qy52v6toqagx"

[dialogic]

