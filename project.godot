; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Living Together with my Childhood Friend: Fantasy Monochrome"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"Asami": "res://Characters/Asami.dch",
"bckup/Asami": "res://Characters/bckup/Asami.dch"
}
directories/dtl_directory={
"timeline1": "res://Timelines/timeline1.dtl"
}
layout/style_directory={}
glossary/default_case_sensitive=true
layout/style_list=[]
layout/default_style=""

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

