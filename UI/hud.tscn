; ════════════════════════════════════════════════════════════════
; HUD — CanvasLayer (layer 10, always on top of gameplay content)
; ════════════════════════════════════════════════════════════════
[node name="HUD" type="CanvasLayer"]
layer = 10
script = ExtResource("1_hud")

; ── Full-screen container — all HUD children go here ─────────────
[node name="HUDContainer" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

; ════════════════════════════════════════════════════════════════
; TOP-LEFT: Time + Day bar
; Anchored to the top-left corner.  Fixed height 44 px.
; ════════════════════════════════════════════════════════════════
[node name="TopBar" type="Control" parent="HUDContainer"]
layout_mode = 1
anchors_preset = 0
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 0.0
anchor_bottom = 0.0
offset_left = 8.0
offset_top = 8.0
offset_right = 218.0
offset_bottom = 48.0

[node name="TopBarBG" type="NinePatchRect" parent="HUDContainer/TopBar"]
modulate = Color(0.02, 0.02, 0.08, 0.88)
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
texture = ExtResource("2_panel")
patch_margin_left = 16
patch_margin_top = 16
patch_margin_right = 16
patch_margin_bottom = 16
axis_stretch_horizontal = 1
axis_stretch_vertical = 1

[node name="TopBarMargin" type="MarginContainer" parent="HUDContainer/TopBar"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 4
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 4

[node name="TopBarHBox" type="HBoxContainer" parent="HUDContainer/TopBar/TopBarMargin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="DayLabel" type="Label" parent="HUDContainer/TopBar/TopBarMargin/TopBarHBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.95, 0.92, 0.85, 1)
theme_override_font_sizes/font_size = 15
text = "Day 1  Mon"

[node name="TimeLabel" type="Label" parent="HUDContainer/TopBar/TopBarMargin/TopBarHBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 15
text = "08:00 AM"

