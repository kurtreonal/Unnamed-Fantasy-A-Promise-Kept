; ════════════════════════════════════════════════════════════════
; BOTTOM BAR: History / Save / Load
; Always visible — even during the prologue.
; Sits directly BELOW the Dialogic dialogue box.
; Anchored to the bottom edge; height auto-fits its buttons.
; ════════════════════════════════════════════════════════════════
[node name="BottomBar" type="Control" parent="HUDContainer"]
layout_mode = 1
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -40.0
offset_bottom = 0.0
grow_vertical = 0

[node name="BottomBarBG" type="NinePatchRect" parent="HUDContainer/BottomBar"]
modulate = Color(0.02, 0.02, 0.07, 0.92)
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
texture = ExtResource("2_panel")
patch_margin_left = 16
patch_margin_top = 16
patch_margin_right = 16
patch_margin_bottom = 16
axis_stretch_horizontal = 1
axis_stretch_vertical = 1

[node name="BottomBarMargin" type="MarginContainer" parent="HUDContainer/BottomBar"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 5
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 5

[node name="BottomBarHBox" type="HBoxContainer" parent="HUDContainer/BottomBar/BottomBarMargin"]
layout_mode = 2
theme_override_constants/separation = 8
alignment = 1

; History button
[node name="BtnHistory" type="Button" parent="HUDContainer/BottomBar/BottomBarMargin/BottomBarHBox"]
custom_minimum_size = Vector2(90, 0)
layout_mode = 2
theme_override_colors/font_color = Color(0.90, 0.90, 1.0, 1)
theme_override_font_sizes/font_size = 13
text = "History"

; Save button
[node name="BtnSave" type="Button" parent="HUDContainer/BottomBar/BottomBarMargin/BottomBarHBox"]
custom_minimum_size = Vector2(74, 0)
layout_mode = 2
theme_override_colors/font_color = Color(0.85, 1.0, 0.85, 1)
theme_override_font_sizes/font_size = 13
text = "Save"

; Load button (enabled only when a save exists — checked in hud.gd)
[node name="BtnLoad" type="Button" parent="HUDContainer/BottomBar/BottomBarMargin/BottomBarHBox"]
custom_minimum_size = Vector2(74, 0)
layout_mode = 2
theme_override_colors/font_color = Color(0.85, 0.92, 1.0, 1)
theme_override_font_sizes/font_size = 13
text = "Load"

; ════════════════════════════════════════════════════════════════
; HISTORY OVERLAY — full-screen modal, toggled by BtnHistory
; ════════════════════════════════════════════════════════════════
[node name="HistoryOverlay" type="Control" parent="HUDContainer"]
